        <title>Zabbix-Grafana图形展示软件</title>
        <link rel="alternate" href="http://example.com/category/2d9a2ff9eff9.html"/>
        <content type="html">&lt;h2 id=&#34;下载grafana-rpm包&#34;&gt;&lt;a class=&#34;markdownIt-Anchor&#34; href=&#34;#下载grafana-rpm包&#34;&gt;#&lt;/a&gt; 下载 grafana rpm 包&lt;/h2&gt;
&lt;pre&gt;&lt;code&gt;# 下载Rpm包
wget https://dl.grafana.com/oss/release/grafana-7.4.0-1.x86_64.rpm
# 安装grafana
sudo yum install -y grafana-7.4.0-1.x86_64.rpm
# Grafana安装zabbix插件
grafana-cli plugins install alexanderzobnin-zabbix-app
# 安装饼状图
grafana-cli plugins install grafana-piechart-panel
# 开机自启
systemctl enable grafana-server
# 启动
systemctl start grafana-server
地址:ip:3000
# Grafana Zabbix插件配置数据源
URL:http://localhost/api_jsonrpc.php
&lt;/code&gt;&lt;/pre&gt;
</content>
